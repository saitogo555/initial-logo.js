{
	"name": "initial-logo",
	"version": "1.0.0",
	"description": "Generate JavaScript/TypeScript style logo",
	"keywords": [
		"logo",
		"generator",
		"typescript",
		"javascript",
		"initials",
		"browser"
	],
	"author": "saitogo555",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saitogo555/initial-logo.js.git"
	},
	"bugs": {
		"url": "https://github.com/saitogo555/initial-logo.js/issues"
	},
	"homepage": "https://github.com/saitogo555/initial-logo.js#readme",
	"type": "module",
	"bin": {
		"initial-logo": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./adapters/node": {
			"types": "./dist/adapters/node.d.ts",
			"import": "./dist/adapters/node.js",
			"require": "./dist/adapters/node.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"playground": "vite playground",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"prepare": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"@types/fontkit": "^2.0.7",
		"@types/node": "^25.0.3",
		"@vitest/coverage-v8": "^4.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"fontkit": "^2.0.4",
		"sharp": "^0.34.5"
	}
}
